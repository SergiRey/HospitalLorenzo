<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HospitalLorenzo.MenuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HospitalLorenzo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Lorenzo Hospital">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#4879AB">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Doctores" Click="BtnDoctores_Click"
                        Background="Transparent" 
                        FontSize="25" 
                        FontWeight="Bold"
                        Foreground="#ffffff" 
                        Margin="16" 
                        BorderThickness="0"/>
                
                <Button Content="Pacientes" Click="BtnPacientes_Click"
                        Background="Transparent" 
                        FontSize="25" 
                        FontWeight="Bold"
                        Foreground="#ffffff" 
                        Margin="16" 
                        BorderThickness="0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,25,0,25">
                <Image Source="/Assets/logo1.png" Width="400" Height="85"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Agenda" Click="BtnCitas_Click"
                        Background="Transparent" 
                        FontSize="25" 
                        FontWeight="Bold"
                        Foreground="#ffffff" 
                        Margin="16" 
                        BorderThickness="0"/>

                <Button Content="Reportes" Click="BtnReportes_Click"
                        Background="Transparent" 
                        FontSize="25"
                        FontWeight="Bold"
                        Foreground="#ffffff" 
                        Margin="16" 
                        BorderThickness="0"/>
                
                <TextBlock x:Name="FechaText"
                   FontSize="16" FontWeight="Bold"
                   Foreground="White" HorizontalAlignment="Center"/>
                
                <TextBlock x:Name="HoraText"
                   FontSize="20" FontWeight="Bold"
                   Foreground="White" HorizontalAlignment="Center"/>

            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <Frame x:Name="ContentFrame" MinHeight="600"/>
                
                

                <StackPanel Orientation="Horizontal" Spacing="12" Padding="16" Background="#001e3b">

                    <Border Background="#0a2e4a" CornerRadius="10" Padding="10" Width="180">
                        <StackPanel Spacing="8">
                            <Image Source="/Assets/cirugia_liposuccion.png" Width="160" Height="100"/>
                            <TextBlock Text="Liposucción" 
                                           FontSize="13" 
                                           FontWeight="Bold" 
                                           Foreground="White"/>
                            <TextBlock Text="Moldea tu cuerpo eliminando grasa localizada en abdomen, espalda, brazos o piernas. Ideal si ya estás cerca de tu peso pero quieres definir.
                                       Costo: $40,000 – $120,000 MXN 
                                       Anestesia: Local (zonas pequeñas) General (zonas grandes)
                                       Datos útiles:
                                       Recuperación: 2 a 4 semanas
                                       Resultados visibles en 1-3 meses
                                       Requiere faja postoperatoria" 
                                           FontSize="11" 
                                           Foreground="#89c4ff"     
                                           TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#0a2e4a" CornerRadius="10" Padding="10" Width="180">
                        <StackPanel Spacing="8">
                            <Image Source="/Assets/cruz.png" Width="160" Height="100" Stretch="UniformToFill"/>
                            <TextBlock Text="Cirugía Estética" 
                                           FontSize="13" 
                                           FontWeight="Bold" 
                                           Foreground="White"/>
                            <TextBlock Text="Procedimientos de mejora estética con tecnología de punta." 
                                           FontSize="11" 
                                           Foreground="#89c4ff" 
                                           TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#0a2e4a" CornerRadius="10" Padding="10" Width="180">
                        <StackPanel Spacing="8">
                            <Image Source="/Assets/cruz.png" Width="160" Height="100" Stretch="UniformToFill"/>
                            <TextBlock Text="Cirugía Estética" 
                                       FontSize="13" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="Procedimientos de mejora estética con tecnología de punta." 
                                       FontSize="11" 
                                       Foreground="#89c4ff" 
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>