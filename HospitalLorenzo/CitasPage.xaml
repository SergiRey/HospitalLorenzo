<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HospitalLorenzo.CitasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HospitalLorenzo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#f4f7fb" Padding="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Gestión de Citas"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#001e3b"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,16,0,16">
            <Button Content="+ Nueva Cita"
                    Background="#001e3b"
                    Foreground="White"
                    Click="BtnNuevaCita_Click"/>
        </StackPanel>

        <ListView Grid.Row="2"
                  x:Name="ListaCitas"
                  Background="White"
                  CornerRadius="8">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:Cita">
                    <StackPanel Padding="12" Spacing="8">

                        <TextBlock Foreground="#7a8fa6" FontSize="12">
                            <Run Text="ID: "/>
                            <Run Text="{x:Bind Id}"/>
                        </TextBlock>

                        <TextBlock Text="{x:Bind PacienteNombre}"
                                   FontWeight="Bold"
                                   Foreground="#001e3b"/>

                        <TextBlock Text="{x:Bind Motivo}"
                                   Foreground="#7a8fa6"/>

                        <TextBlock Foreground="#001e3b">
                            <Run Text="{x:Bind Fecha}"/>
                            <Run Text=" — "/>
                            <Run Text="{x:Bind Hora}"/>
                        </TextBlock>

                        <TextBlock>
                            <Run Text="Estatus: "/>
                            <Run Text="{x:Bind Estatus}"/>
                        </TextBlock>

                        <ComboBox Tag="{x:Bind Id}"
                                  HorizontalAlignment="Left"
                                  SelectionChanged="CmbEstatus_SelectionChanged">
                            <ComboBoxItem Content="Programada"/>
                            <ComboBoxItem Content="Atendida"/>
                            <ComboBoxItem Content="Cancelada"/>
                        </ComboBox>

                        <Button Content="Guardar cambios"
                                Background="#001e3b"
                                Foreground="White"
                                Tag="{x:Bind Id}"
                                Click="BtnGuardarEstatus_Click"/>

                        <Button Content="PDF"
                                Background="#001e3b"
                                Foreground="White"
                                Tag="{x:Bind Id}"
                                Click="BtnPdfCita_Click"/>

                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel x:Name="PanelNuevaCita"
                    Grid.Row="2"
                    Background="White"
                    CornerRadius="8"
                    Padding="16"
                    Spacing="8"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    Width="350">

            <TextBlock Text="Nueva Cita"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <ComboBox x:Name="cbPacientes"
                      DisplayMemberPath="Nombre"
                      Header="Seleccione un paciente:"
                      SelectedValuePath="Id"/>

            <ComboBox x:Name="cbDoctores"
                      DisplayMemberPath="Nombre"
                      Header="Seleccione un médico:"
                      SelectedValuePath="Id"/>

            <CalendarDatePicker x:Name="dpFechaCita"
                                Header="Fecha de la cita"
                                HorizontalAlignment="Stretch"/>

            <TimePicker x:Name="tpHora"
                        Header="Hora de la cita"
                        ClockIdentifier="24HourClock"/>

            <TextBox x:Name="txtMotivo"
                     Header="Motivo"
                     Height="80"/>

            <Button Content="Guardar Cita"
                    HorizontalAlignment="Stretch"
                    Background="#001e3b"
                    Foreground="White"
                    Click="BtnGuardar_Click"/>

            <Button Content="Cancelar"
                    HorizontalAlignment="Stretch"
                    Click="BtnCancelar_Click"/>

        </StackPanel>
    </Grid>
</Page>