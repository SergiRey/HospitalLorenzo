<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HospitalLorenzo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HospitalLorenzo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="LogInApp - Hospital Lorenzo">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid Grid.Column="0">
            
            <Grid.Background>
                <ImageBrush ImageSource="/Assets/hospital_log_bg.PNG" Stretch="UniformToFill" Opacity="0.95"/>
            </Grid.Background>
            <TextBlock Text="CLÍNICA" Foreground="White" FontWeight="ExtraBold" FontSize="55" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 200, 0, 0"/>
            <TextBlock Text="LORENZO" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 280, 0, 0"/>


            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16">

                <Image Source="/Assets/Logo_white.png"
                       Width="500" Height="280"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,170"
                       Opacity="0.90"/>


            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="#ffffff">
            <FontIcon Glyph="&#xEA8C;" FontSize="75" Foreground="#4879AB" VerticalAlignment="Top" Margin="0, 110, 0, 0"/>
            <Button Name="fileExitMenuItem" Click="fileExitMenuItem_Click" Background="#ef8278" HorizontalAlignment="Center" Margin="0,435,0,0">
                <FontIcon Glyph="&#xF78A;" Foreground="#a61d10" FontSize="15"/>
            </Button>
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="300"
                        Spacing="12">

                <TextBlock Text="Inicio de Sesión"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="#4879AB"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="UsernameTextBox"
                         Header="Usuario"
                         FontWeight="SemiLight"
                         PlaceholderText="Introduzca su Usuario"
                         Foreground="#4879AB"
                         MaxLength="30"/>
                <TextBlock x:Name="ErrorUsuario" Grid.Row="1" Grid.Column="0"
                                           FontSize="11" Foreground="Red"
                                           Visibility="Collapsed" Margin="0,2,0,6"/>

                <PasswordBox x:Name="PasswordBox"
                             Header="Contraseña"
                             FontWeight="SemiLight"
                             PlaceholderText="Introduzca su Contraseña"
                             Foreground="#4879AB"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <StackPanel x:Name="ReglasPanel" Spacing="4" Margin="0,6,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="ReglaTamano"   Text="✗ Mínimo 3 caracteres"      FontSize="12" Foreground="Red"/>
                    <TextBlock x:Name="ReglaMayuscula" Text="✗ Al menos una mayúscula"   FontSize="12" Foreground="Red"/>
                    <TextBlock x:Name="ReglaNumero"   Text="✗ Al menos un número"        FontSize="12" Foreground="Red"/>
                    <TextBlock x:Name="ReglaEspecial" Text="✗ Al menos un carácter especial (!@#$...)" FontSize="12" Foreground="Red"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Margin="0,12,0,0">
                    <Button x:Name="CreateUserButton"
                            Content="Crear usuario"
                            Click="CreateUser_Click"
                            Foreground="#1A5B1A"
                            Background="#C0EDC0"/>
                    <Button x:Name="LoginButton"
                            Content="Iniciar sesión"
                            Click="Login_Click"
                            Foreground="#19475C"
                            Background="#ACD5E8"/>
                </StackPanel>

                <TextBlock x:Name="StatusTextBlock"
                           Foreground="Red"
                           FontWeight="ExtraLight"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>